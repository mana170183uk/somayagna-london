# ─── Database (Neon Postgres) ───────────────────────────────────────────────
# Use the Neon connection string with `?sslmode=require`
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.eu-west-2.aws.neon.tech/somayagna?sslmode=require"
# Optional pooled URL for Vercel serverless (Neon "Pooled connection")
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.eu-west-2.aws.neon.tech/somayagna?sslmode=require"

# ─── Event configuration (editable without code changes) ────────────────────
EVENT_YEAR="2026"
EVENT_VENUE_NAME="Venue to be announced"
EVENT_VENUE_ADDRESS="London, United Kingdom"
EVENT_CONTACT_EMAIL="info@somayagnalondon.org"
EVENT_CONTACT_PHONE="+44 20 0000 0000"
EVENT_ORGANIZER="Unity in Divinity (UK Registered Charity)"

# ─── Public site URL ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Payments ───────────────────────────────────────────────────────────────
# Set ENABLED_PAYMENT_PROVIDERS to any comma-separated mix of: stripe, paypal, mock
ENABLED_PAYMENT_PROVIDERS="mock,stripe,paypal"

# Stripe (use test keys for sandbox)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_ENABLED="false"

# PayPal (sandbox or live)
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"       # "sandbox" or "live"
PAYPAL_WEBHOOK_ID=""
NEXT_PUBLIC_PAYPAL_ENABLED="false"

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="SomaYagna London <bookings@somayagnalondon.org>"

# ─── Admin auth (simple cookie session) ─────────────────────────────────────
ADMIN_EMAIL="admin@somayagnalondon.org"
ADMIN_PASSWORD="changeme-please"
ADMIN_SESSION_SECRET="generate-a-long-random-string-here"
