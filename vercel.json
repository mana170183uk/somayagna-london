{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && prisma db push --skip-generate --force-reset && tsx prisma/seed.ts && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["lhr1"],
  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "functions": {
    "src/app/api/webhooks/stripe/route.ts": { "maxDuration": 30 },
    "src/app/api/webhooks/paypal/route.ts": { "maxDuration": 30 }
  }
}
