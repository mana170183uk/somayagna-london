// SomaYagna London — Prisma schema (Neon PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum YagnaType {
  PURSHOTAM         // 14, 15 June
  VISHNU_GOPAL      // 16–21 June
  PITRU             // every active day
}

enum BookingType {
  SINGLE_POSITION
  FULL_KUND
}

enum BookingStatus {
  PENDING_PAYMENT   // hold placed, payment in flight
  CONFIRMED         // payment success
  CANCELLED         // refunded / admin cancelled
  EXPIRED           // hold expired before payment
  FAILED            // payment failed
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MOCK
  ADMIN_MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum Relation {
  COUPLE
  SIBLING
  INDIVIDUAL
}

model EventDay {
  id             String          @id @default(cuid())
  date           DateTime        @unique          // midnight UTC of the event day
  description    String?         @db.Text
  yagnaInstances YagnaInstance[]
  createdAt      DateTime        @default(now())

  @@index([date])
}

// One yagna running on a given day (e.g. Mon 15 = Purshotam + Pitru = 2 instances).
// Each YagnaInstance has its OWN Kund inventory (Pitru's 9 Kunds ≠ Vishnu Gopal's 11 Kunds).
model YagnaInstance {
  id          String    @id @default(cuid())
  eventDayId  String
  eventDay    EventDay  @relation(fields: [eventDayId], references: [id], onDelete: Cascade)
  yagnaType   YagnaType
  title       String                          // human-friendly e.g. "Pitru Yagna"
  kundCount   Int                             // 11 (Purshotam/Vishnu Gopal) or 9 (Pitru)
  sessions    Session[]
  createdAt   DateTime  @default(now())

  @@unique([eventDayId, yagnaType])
  @@index([eventDayId])
}

model Session {
  id                String         @id @default(cuid())
  yagnaInstanceId   String
  yagnaInstance     YagnaInstance  @relation(fields: [yagnaInstanceId], references: [id], onDelete: Cascade)
  startTime         String                          // "10:15" (24h, Europe/London)
  label             String                          // "Morning", "Late Morning", etc.
  optional          Boolean        @default(false)  // 'if there is demand' sessions per SM doc
  enabled           Boolean        @default(true)   // admin can disable to hide from public booking page
  kunds             Kund[]
  bookings          Booking[]
  holds             BookingHold[]
  createdAt         DateTime       @default(now())

  @@unique([yagnaInstanceId, startTime])
  @@index([yagnaInstanceId])
}

model Kund {
  id         String          @id @default(cuid())
  sessionId  String
  session    Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  number     Int             // 1..11
  positions  KundPosition[]

  @@unique([sessionId, number])
  @@index([sessionId])
}

// One row per (kund × position). Inventory truth lives here.
model KundPosition {
  id         String     @id @default(cuid())
  kundId     String
  kund       Kund       @relation(fields: [kundId], references: [id], onDelete: Cascade)
  label      String     // "A" | "B" | "C"

  bookingId  String?                     // confirmed owner (NULL if free). NOT unique: a Full Kund booking owns 3 positions
  booking    Booking?   @relation("ConfirmedPositions", fields: [bookingId], references: [id], onDelete: SetNull)

  holdId     String?                     // active hold (NULL if free). NOT unique: a Full Kund hold owns 3 positions
  hold       BookingHold? @relation("HeldPositions", fields: [holdId], references: [id], onDelete: SetNull)

  // Admin-blocked: reserved for VIP / off-line use. Treated as taken in availability.
  blocked     Boolean   @default(false)
  blockReason String?
  blockedAt   DateTime?
  blockedBy   String?                     // admin email who placed the block

  @@unique([kundId, label])
  @@index([kundId])
  @@index([holdId])
  @@index([bookingId])
}

// A short-lived (10 min) reservation while the user completes payment.
model BookingHold {
  id           String         @id @default(cuid())
  sessionId    String
  session      Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  bookingType  BookingType
  kundNumber   Int                                   // 1..11
  positions    String[]                              // ["A"] or ["A","B","C"]
  amountPence  Int                                   // £201 -> 20100, £501 -> 50100
  currency     String         @default("GBP")
  email        String
  primaryName  String
  expiresAt    DateTime
  createdAt    DateTime       @default(now())

  heldPositions KundPosition[] @relation("HeldPositions")
  booking       Booking?

  @@index([sessionId])
  @@index([expiresAt])
}

model Booking {
  id              String         @id @default(cuid())
  reference       String         @unique             // human-friendly "SY-2026-000123"
  sessionId       String
  session         Session        @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  holdId          String?        @unique
  hold            BookingHold?   @relation(fields: [holdId], references: [id], onDelete: SetNull)
  bookingType     BookingType
  kundNumber      Int
  positions       String[]                            // ["A"] or ["A","B","C"]
  amountPence     Int
  donationPence   Int            @default(0)             // optional charity donation alongside booking
  currency        String         @default("GBP")
  status          BookingStatus  @default(PENDING_PAYMENT)

  primaryName     String
  relation        Relation
  email           String?                                  // now optional - WhatsApp is primary channel
  phone           String
  whatsappNumber  String?                                  // primary booking-confirmation channel
  secondParticipantName String?

  // Optional address fields for Gift Aid (UK HMRC requires for claim)
  addressLine1    String?
  town            String?
  postcode        String?
  giftAid         Boolean        @default(false)           // donor declared UK taxpayer for Gift Aid

  confirmedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?

  payment         Payment?
  confirmedPositions KundPosition[] @relation("ConfirmedPositions")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([sessionId])
  @@index([email])
  @@index([status])
}

model Payment {
  id              String           @id @default(cuid())
  bookingId       String           @unique
  booking         Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  provider        PaymentProvider
  providerRef     String?                              // Stripe session id or PayPal order id
  amountPence     Int
  currency        String           @default("GBP")
  status          PaymentStatus    @default(PENDING)
  rawWebhook      Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([providerRef])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String                                  // scrypt; see lib/auth.ts
  name         String?
  createdAt    DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String                                     // admin email or "system"
  action    String                                     // "CANCEL_BOOKING", "EDIT_BOOKING", ...
  target    String?                                    // booking id, session id, etc.
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/* ─────────────────────────  Donations  ───────────────────────── */

enum DonationType {
  GENERAL          // free-text custom amount
  MATERIAL         // toward a specific material (ghee, prasad, etc.)
}

enum DonationStatus {
  PENDING_PAYMENT
  COMPLETED
  FAILED
  REFUNDED
}

model Donation {
  id              String            @id @default(cuid())
  reference       String            @unique             // SY-DON-2026-XXXXXX
  type            DonationType
  materialKey     String?                                // "ghee" | "prasad" | "annadana" | ...
  materialLabel   String?                                // "Ghee for the sacred fire"
  amountPence     Int
  currency        String            @default("GBP")

  // Donor
  donorName       String
  donorEmail      String
  donorPhone      String?
  message         String?           @db.Text             // optional dedication / words
  anonymous       Boolean           @default(false)
  giftAid         Boolean           @default(false)      // UK HMRC Gift Aid declaration
  giftAidAddress  String?                                // required by HMRC if giftAid=true
  giftAidPostcode String?

  status          DonationStatus    @default(PENDING_PAYMENT)
  paymentProvider PaymentProvider?
  paymentRef      String?
  rawWebhook      Json?

  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([donorEmail])
  @@index([materialKey])
}
